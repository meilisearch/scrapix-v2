# =============================================================================
# Scrapix Environment Configuration
# =============================================================================
# Copy this file to .env and update the values as needed
# =============================================================================

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# Optional: API authentication key (leave empty to disable)
# API_KEY=your-secret-api-key

# -----------------------------------------------------------------------------
# Kafka/Redpanda Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of broker addresses
KAFKA_BROKERS=localhost:19092

# Consumer group IDs (usually set per-service)
# KAFKA_GROUP_ID=scrapix-crawlers

# -----------------------------------------------------------------------------
# Meilisearch Configuration
# -----------------------------------------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# -----------------------------------------------------------------------------
# Redis/DragonflyDB Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log levels: error, warn, info, debug, trace
# Can be filtered per-module: RUST_LOG=info,scrapix=debug
RUST_LOG=info,scrapix=debug

# -----------------------------------------------------------------------------
# Frontier Service Configuration
# -----------------------------------------------------------------------------
DISPATCH_INTERVAL_MS=100
DISPATCH_BATCH_SIZE=100
DOMAIN_DELAY_MS=1000
BLOOM_CAPACITY=10000000
BLOOM_FP_RATE=0.01

# -----------------------------------------------------------------------------
# Crawler Worker Configuration
# -----------------------------------------------------------------------------
CONCURRENCY=10
USER_AGENT=Scrapix/1.0 (compatible; +https://github.com/quentindequelen/scrapix)
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_DEPTH=100
MAX_BODY_SIZE=10485760
RESPECT_ROBOTS=true

# -----------------------------------------------------------------------------
# Content Worker Configuration
# -----------------------------------------------------------------------------
BATCH_SIZE=100
BATCH_TIMEOUT_SECS=5

# -----------------------------------------------------------------------------
# AI Features (Optional)
# -----------------------------------------------------------------------------
# Required for AI extraction, summarization, and embeddings
# OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# Object Storage (Optional)
# -----------------------------------------------------------------------------
# S3-compatible storage for raw HTML archiving
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=scrapix-archive
# S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Telemetry (Optional)
# -----------------------------------------------------------------------------
# OpenTelemetry OTLP endpoint for distributed tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Prometheus metrics port
# METRICS_PORT=9090
