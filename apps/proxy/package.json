{
  "name": "@scrapix/proxy",
  "license": "MIT",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts --exec 'tsc && node dist/index.js'",
    "start": "node dist/index.js",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --config ../../eslint.config.mjs",
    "lint:fix": "eslint src --fix --config ../../eslint.config.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "http-proxy": "^1.18.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/http-proxy": "^1.17.14"
  }
}
