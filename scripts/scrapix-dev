#!/usr/bin/env bash
# Scrapix Development CLI
# Unified tool for testing, benchmarking, and deployment

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_ROOT"

VERSION="1.0.0"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

show_banner() {
    echo -e "${CYAN}"
    cat << 'EOF'
   ____                       _
  / ___|  ___ _ __ __ _ _ __ (_)_  __
  \___ \ / __| '__/ _` | '_ \| \ \/ /
   ___) | (__| | | (_| | |_) | |>  <
  |____/ \___|_|  \__,_| .__/|_/_/\_\
                       |_|
EOF
    echo -e "${NC}"
    echo -e "  ${BOLD}Development CLI v${VERSION}${NC}"
    echo ""
}

usage() {
    show_banner
    cat << EOF
${BOLD}USAGE:${NC}
    scrapix-dev <COMMAND> [OPTIONS]

${BOLD}COMMANDS:${NC}
    ${GREEN}test${NC}        Run test crawls with timing and metrics
    ${GREEN}bench${NC}       Run performance benchmarks
    ${GREEN}k8s${NC}         Kubernetes deployment management
    ${GREEN}monitor${NC}     Real-time monitoring dashboard
    ${GREEN}infra${NC}       Manage local infrastructure (docker-compose)
    ${GREEN}build${NC}       Build release binaries
    ${GREEN}clean${NC}       Clean up build artifacts and data
    ${GREEN}help${NC}        Show this help message

${BOLD}QUICK START:${NC}
    # Run a quick Wikipedia crawl test
    scrapix-dev test wikipedia-1k

    # Run benchmarks
    scrapix-dev bench wikipedia

    # Deploy to Kubernetes
    scrapix-dev k8s deploy

    # Monitor a running crawl
    scrapix-dev monitor

${BOLD}EXAMPLES:${NC}
    scrapix-dev test wikipedia-10k -c 100 -d 20
    scrapix-dev bench -i 3 integrated
    scrapix-dev k8s scale crawler -r 5
    scrapix-dev monitor -c

${BOLD}OPTIONS:${NC}
    -h, --help      Show help for a specific command
    -v, --version   Show version

Run 'scrapix-dev <command> --help' for more information on a command.
EOF
}

cmd_infra() {
    local action="${1:-}"

    case "$action" in
        up|start)
            echo -e "${BLUE}[INFO]${NC} Starting infrastructure..."
            docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
            echo -e "${GREEN}[OK]${NC} Infrastructure started"
            echo ""
            echo "Services:"
            echo "  - Redpanda (Kafka):    localhost:19092"
            echo "  - Meilisearch:         localhost:7700"
            echo "  - DragonflyDB (Redis): localhost:6380"
            echo "  - Redpanda Console:    localhost:8090"
            ;;
        down|stop)
            echo -e "${BLUE}[INFO]${NC} Stopping infrastructure..."
            docker compose -f docker-compose.yml -f docker-compose.dev.yml down
            echo -e "${GREEN}[OK]${NC} Infrastructure stopped"
            ;;
        restart)
            echo -e "${BLUE}[INFO]${NC} Restarting infrastructure..."
            docker compose -f docker-compose.yml -f docker-compose.dev.yml restart
            echo -e "${GREEN}[OK]${NC} Infrastructure restarted"
            ;;
        status|ps)
            docker compose ps
            ;;
        logs)
            shift 2>/dev/null || true
            docker compose logs "$@"
            ;;
        reset)
            echo -e "${YELLOW}[WARN]${NC} This will delete all data volumes"
            read -p "Are you sure? (y/N) " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v
                echo -e "${GREEN}[OK]${NC} Infrastructure reset"
            fi
            ;;
        *)
            cat << EOF
Usage: scrapix-dev infra <ACTION>

Manage local development infrastructure

ACTIONS:
    up, start     Start all infrastructure services
    down, stop    Stop all infrastructure services
    restart       Restart all infrastructure services
    status, ps    Show status of infrastructure services
    logs          Show logs (optionally specify service name)
    reset         Stop and remove all data volumes

EXAMPLES:
    scrapix-dev infra up
    scrapix-dev infra logs redpanda
    scrapix-dev infra reset
EOF
            ;;
    esac
}

cmd_build() {
    local mode="${1:-release}"

    echo -e "${BLUE}[INFO]${NC} Building Scrapix ($mode mode)..."

    if [[ "$mode" == "debug" ]]; then
        cargo build --bin scrapix-api --bin scrapix-worker-crawler \
            --bin scrapix-worker-content --bin scrapix-frontier-service --bin scrapix
    else
        cargo build --release --bin scrapix-api --bin scrapix-worker-crawler \
            --bin scrapix-worker-content --bin scrapix-frontier-service --bin scrapix
    fi

    echo -e "${GREEN}[OK]${NC} Build complete"

    echo ""
    echo "Binaries:"
    ls -lh target/$mode/scrapix* 2>/dev/null | awk '{print "  " $NF ": " $5}'
}

cmd_clean() {
    echo -e "${BLUE}[INFO]${NC} Cleaning up..."

    # Clean Rust build artifacts
    if [[ "${1:-}" == "--all" ]]; then
        cargo clean
        echo "  - Removed Rust build artifacts"
    fi

    # Clean crawl results
    if [[ -d "./crawl-results" ]]; then
        rm -rf ./crawl-results
        echo "  - Removed crawl results"
    fi

    # Clean bench results
    if [[ -d "./bench-results" ]]; then
        rm -rf ./bench-results
        echo "  - Removed benchmark results"
    fi

    # Clean RocksDB data
    if [[ -d "./data" ]]; then
        rm -rf ./data
        echo "  - Removed local data (RocksDB)"
    fi

    echo -e "${GREEN}[OK]${NC} Cleanup complete"
}

main() {
    local command="${1:-}"

    if [[ -z "$command" || "$command" == "-h" || "$command" == "--help" || "$command" == "help" ]]; then
        usage
        exit 0
    fi

    if [[ "$command" == "-v" || "$command" == "--version" ]]; then
        echo "scrapix-dev v${VERSION}"
        exit 0
    fi

    shift

    case "$command" in
        test)
            exec "$SCRIPT_DIR/test-crawl.sh" "$@"
            ;;
        bench)
            exec "$SCRIPT_DIR/bench.sh" "$@"
            ;;
        k8s|kubernetes)
            exec "$SCRIPT_DIR/k8s.sh" "$@"
            ;;
        monitor)
            exec "$SCRIPT_DIR/monitor.sh" "$@"
            ;;
        infra|infrastructure)
            cmd_infra "$@"
            ;;
        build)
            cmd_build "$@"
            ;;
        clean)
            cmd_clean "$@"
            ;;
        *)
            echo -e "${RED}[ERROR]${NC} Unknown command: $command"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
